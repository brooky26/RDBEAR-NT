# ---- Deriv API ----
# Get DERIV_APP_ID from developers.deriv.com (legacy app_ids like 1089 do NOT
# work with the new Options API).
DERIV_APP_ID=
DERIV_API_TOKEN=
# "demo" (default/safe) or "real". Kept explicit so the bot never trades
# real money by accident.
DERIV_ACCOUNT_TYPE=demo
# Optional — skips the account lookup and uses this account_id directly.
DERIV_ACCOUNT_ID=

# ---- Supabase persistence ----
# Run schema.sql in the Supabase SQL editor once before the first deploy.
SUPABASE_URL=
SUPABASE_KEY=

# ---- Logging ----
# Set to 1 for per-cycle debug logs (barrier sigma sweeps, gate rejections).
# Leave at 0 for normal operation — verbose logging is noisy at 2s scan
# cadence on Railway's log viewer.
VERBOSE_LOGS=0
